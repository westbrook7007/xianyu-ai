# Supabase（免费版）https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 爬虫 API 密钥（GitHub Actions / Replit 调用后端时使用）
CRAWL_API_SECRET=change-me-to-random-string

# 爬虫配置（可选覆盖）
CRAWL_MIN_ITEMS=20
CRAWL_MAX_ITEMS=30
CRAWL_INTERVAL_SECONDS=30

# 评分权重（可选，默认见 src/lib/config.ts）
# SCORE_WEIGHT_PRICE=35
